{
  "manifest_version": 3,
  "name": "SmartFlow360",
  "version": "1.0.0",
  "description": "Auto-assist during meetings: extract notes, dictate add-ons, analyze, and email report.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "tabs", "microphone"],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*",
        "https://*.webex.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}